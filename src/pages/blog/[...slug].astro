---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = (await getCollection('blog')).filter((p) => !p.data.draft);
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await post.render();

function estimateReadTimeMinutes(text: string) {
  const words = text.split(/\s+/).filter(Boolean).length;
  return Math.max(1, Math.round(words / 200));
}

const readTime = post.data.readTime ?? estimateReadTimeMinutes(post.body);
const hasReadTime = Number.isFinite(readTime) && readTime > 0;

const formattedDate = post.data.date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: '2-digit',
});

const toc = (headings ?? []).filter((h) => h.depth >= 2 && h.depth <= 3);

const rawDescription = typeof post.data.description === 'string' ? post.data.description : '';
const descriptionLead = (rawDescription.split(/\r?\n/).find((l) => l.trim().length > 0) ?? '').trim();
const firstParagraph =
  (post.body
    .split(/\r?\n\s*\r?\n/)
    .map((b) => b.trim())
    .find((b) => b.length > 0 && !b.startsWith('#')) ??
    '').trim();

const normalizeText = (s: string) =>
  s
    .replace(/[\u2018\u2019]/g, "'")
    .replace(/[\u201C\u201D]/g, '"')
    .replace(/\s+/g, ' ')
    .trim()
    .toLowerCase();

const stripTrailingEllipsis = (s: string) => s.replace(/[\.\u2026]+\s*$/, '').trim();

const leadNorm = normalizeText(stripTrailingEllipsis(descriptionLead));
const paraNorm = normalizeText(firstParagraph);

const leadLooksDuplicated =
  leadNorm.length > 0 &&
  paraNorm.length > 0 &&
  (leadNorm === paraNorm || paraNorm.startsWith(leadNorm) || leadNorm.startsWith(paraNorm));

const shouldRenderLead = descriptionLead.length > 0 && !leadLooksDuplicated;

const pageDescription = (descriptionLead || firstParagraph).replace(/\s+/g, ' ').trim().slice(0, 180);

function escapeHtml(input: string) {
  return input
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;');
}

function renderInlineCode(input: string) {
  const codeClass =
    'rounded bg-zinc-100 px-1 py-0.5 font-mono text-[0.9em] text-zinc-900 dark:bg-zinc-800 dark:text-zinc-100';

  let out = '';
  let i = 0;

  while (i < input.length) {
    const tick = input.indexOf('`', i);
    if (tick === -1) {
      out += escapeHtml(input.slice(i));
      break;
    }

    out += escapeHtml(input.slice(i, tick));

    const isDouble = input.startsWith('``', tick);
    const openLen = isDouble ? 2 : 1;
    const close = input.indexOf(isDouble ? '``' : '`', tick + openLen);

    if (close === -1) {
      out += escapeHtml(input.slice(tick, tick + openLen));
      i = tick + openLen;
      continue;
    }

    const codeText = input.slice(tick + openLen, close);
    out += `<code class="${codeClass}">${escapeHtml(codeText)}</code>`;
    i = close + openLen;
  }

  return out;
}
---

<BaseLayout title={post.data.title} description={pageDescription} containerClass="max-w-6xl">
  <div class="lg:grid lg:grid-cols-[minmax(0,1fr)_20rem] lg:gap-10">
    <article class="openai-prose mx-auto w-full max-w-[46rem] min-w-0">
      <div class="not-prose mb-8 space-y-3">
        <a
          href="/"
          class="text-sm text-zinc-600 no-underline hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-white"
        >
          ← Back
        </a>
        <h1 class="mb-0 text-[40px] leading-[1.1] font-semibold tracking-tight">
          <span set:html={renderInlineCode(post.data.title)} />
        </h1>

        <div class="mt-5 flex flex-wrap items-center justify-between gap-4 text-sm text-zinc-600 dark:text-zinc-400">
          <div class="flex flex-wrap items-center gap-3">
            <span>{formattedDate}</span>
            {hasReadTime && (
              <span class="inline-flex items-center gap-1">
                <svg
                  class="h-3.5 w-3.5"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <circle cx="12" cy="12" r="10" />
                  <path d="M12 6v6l4 2" />
                </svg>
                <span>{readTime} minutes</span>
              </span>
            )}
          </div>

          <div class="flex items-center gap-2">
            <span class="hidden sm:inline">Share:</span>
            <button
              type="button"
              data-share="x"
              class="grid h-8 w-8 place-items-center rounded-full border border-zinc-200 text-zinc-700 transition-colors hover:bg-zinc-50 dark:border-zinc-800 dark:text-zinc-200 dark:hover:bg-zinc-900"
              aria-label="Share on X"
            >
              <svg viewBox="0 0 24 24" class="h-4 w-4" aria-hidden="true" fill="currentColor">
                <path
                  d="M18.9 2H22l-6.8 7.8L23 22h-6.6l-5.2-6.7L5.3 22H2l7.4-8.5L1 2h6.7l4.7 6.1L18.9 2zm-1.1 18h1.7L6.8 4H5L17.8 20z"
                />
              </svg>
            </button>

            <button
              type="button"
              data-share="facebook"
              class="grid h-8 w-8 place-items-center rounded-full border border-zinc-200 text-zinc-700 transition-colors hover:bg-zinc-50 dark:border-zinc-800 dark:text-zinc-200 dark:hover:bg-zinc-900"
              aria-label="Share on Facebook"
            >
              <svg viewBox="0 0 24 24" class="h-4 w-4" aria-hidden="true" fill="currentColor">
                <path
                  d="M13.5 22v-8h2.7l.4-3h-3.1V9.1c0-.9.3-1.5 1.6-1.5h1.7V5c-.3 0-1.5-.1-2.8-.1-2.8 0-4.6 1.7-4.6 4.8V11H7v3h2.7v8h3.8z"
                />
              </svg>
            </button>

            <button
              type="button"
              data-share="linkedin"
              class="grid h-8 w-8 place-items-center rounded-full border border-zinc-200 text-zinc-700 transition-colors hover:bg-zinc-50 dark:border-zinc-800 dark:text-zinc-200 dark:hover:bg-zinc-900"
              aria-label="Share on LinkedIn"
            >
              <svg viewBox="0 0 24 24" class="h-4 w-4" aria-hidden="true" fill="currentColor">
                <path
                  d="M20.5 3h-17C2.7 3 2 3.7 2 4.5v17c0 .8.7 1.5 1.5 1.5h17c.8 0 1.5-.7 1.5-1.5v-17c0-.8-.7-1.5-1.5-1.5zM8 20H5v-9h3v9zM6.5 9.8C5.5 9.8 4.7 9 4.7 8s.8-1.8 1.8-1.8 1.8.8 1.8 1.8-.8 1.8-1.8 1.8zM20 20h-3v-4.9c0-1.2 0-2.7-1.7-2.7s-2 1.3-2 2.6V20h-3v-9h2.9v1.2h.1c.4-.8 1.4-1.7 2.9-1.7 3.1 0 3.7 2 3.7 4.7V20z"
                />
              </svg>
            </button>
          </div>
        </div>

        <div class="pt-3">
          <div class="h-px w-full bg-zinc-200 dark:bg-zinc-800"></div>
        </div>
      </div>
      <Content />
    </article>

    <script is:inline>
      (() => {
        const copyText = async (text) => {
          try {
            if (navigator.clipboard && navigator.clipboard.writeText) {
              await navigator.clipboard.writeText(text);
              return true;
            }
          } catch {
            // ignore
          }

          try {
            const el = document.createElement('textarea');
            el.value = text;
            el.setAttribute('readonly', '');
            el.style.position = 'fixed';
            el.style.left = '-9999px';
            document.body.appendChild(el);
            el.select();
            document.execCommand('copy');
            document.body.removeChild(el);
            return true;
          } catch {
            return false;
          }
        };

        const setupShare = () => {
          const buttons = document.querySelectorAll('button[data-share]');
          if (!buttons.length) return;

          const getShareUrl = (provider, pageUrl) => {
            const u = encodeURIComponent(pageUrl);
            switch (provider) {
              case 'x':
                return `https://twitter.com/intent/tweet?url=${u}`;
              case 'facebook':
                return `https://www.facebook.com/sharer/sharer.php?u=${u}`;
              case 'linkedin':
                return `https://www.linkedin.com/sharing/share-offsite/?url=${u}`;
              default:
                return '';
            }
          };

          buttons.forEach((btn) => {
            btn.addEventListener('click', async () => {
              if (!(btn instanceof HTMLElement)) return;
              const provider = btn.getAttribute('data-share');
              const pageUrl = window.location.href;
              const shareUrl = getShareUrl(provider, pageUrl);
              if (!shareUrl) {
                const ok = await copyText(pageUrl);
                if (ok && typeof window.__toast === 'function') window.__toast('Copied link');
                return;
              }
              window.open(shareUrl, '_blank', 'noopener,noreferrer');
            });
          });
        };

        const setupTocScrollSpy = () => {
          const aside = document.querySelector('aside[data-toc]');
          if (!aside) return;

          const links = Array.from(aside.querySelectorAll('a[data-toc-link]'));
          if (!links.length) return;

          const map = new Map();
          for (const a of links) {
            const id = a.getAttribute('data-toc-link');
            if (id) map.set(id, a);
          }

          const headings = Array.from(
            document.querySelectorAll('article.prose h2[id], article.prose h3[id]')
          ).filter((h) => map.has(h.getAttribute('id')));

          if (!headings.length) return;

          let activeId = '';

          const setActive = (id) => {
            if (!id || id === activeId) return;
            const prev = activeId ? map.get(activeId) : null;
            if (prev) {
              prev.removeAttribute('data-active');
              prev.removeAttribute('aria-current');
            }
            const next = map.get(id);
            if (next) {
              next.setAttribute('data-active', 'true');
              next.setAttribute('aria-current', 'true');
              activeId = id;
            }
          };

          const computeActive = () => {
            const offset = 140;
            let current = headings[0].getAttribute('id');
            for (const h of headings) {
              const top = h.getBoundingClientRect().top;
              if (top - offset <= 0) current = h.getAttribute('id');
              else break;
            }
            if (current) setActive(current);
          };

          let ticking = false;
          const onScroll = () => {
            if (ticking) return;
            ticking = true;
            window.requestAnimationFrame(() => {
              computeActive();
              ticking = false;
            });
          };

          window.addEventListener('scroll', onScroll, { passive: true });
          window.addEventListener('resize', onScroll);
          computeActive();

          for (const a of links) {
            a.addEventListener('click', () => {
              const id = a.getAttribute('data-toc-link');
              if (!id) return;
              window.setTimeout(() => setActive(id), 0);
            });
          }
        };

        const init = () => {
          setupShare();
          setupTocScrollSpy();

          const root = document.querySelector('article.prose');
          if (!root) return;

          root.addEventListener('click', async (e) => {
            const target = e.target;
            if (!(target instanceof HTMLElement)) return;

            const heading = target.closest('h2[id], h3[id], h4[id], h5[id], h6[id]');
            if (!heading) return;

            if (target.closest('a')) return;

            const id = heading.getAttribute('id');
            if (!id) return;

            const url = `${location.origin}${location.pathname}#${id}`;
            const ok = await copyText(url);
            if (ok) {
              history.replaceState(null, '', `#${id}`);
              if (typeof window.__toast === 'function') {
                window.__toast('Copied link');
              }
            }
          });
        };

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', init);
        } else {
          init();
        }
      })();
    </script>

    <aside class="hidden lg:block" data-toc>
      <div class="sticky top-24 max-h-[calc(100vh-8rem)] overflow-auto">
        <div class="text-[16px] font-semibold text-zinc-700 dark:text-zinc-50">Table of Contents</div>
        <div class="mt-3 h-px w-full bg-zinc-200 dark:bg-zinc-800"></div>
        {toc.length > 0 ? (
          <nav class="mt-4">
            <ul class="space-y-1 text-sm">
              {toc.map((h) => (
                <li class={h.depth === 3 ? 'pl-4' : ''}>
                  <a
                    data-toc-link={h.slug}
                    class="toc-link block rounded-lg px-3 py-2 no-underline text-zinc-700 transition-colors dark:text-zinc-300"
                    href={`#${h.slug}`}
                  >
                    <span class="leading-snug">{h.text}</span>
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        ) : (
          <div class="mt-3 text-sm text-zinc-600 dark:text-zinc-400">No headings</div>
        )}
      </div>
    </aside>
  </div>

  <style is:inline>
    a.toc-link:hover {
      background: rgb(var(--brand-primary-rgb) / 0.09);
      color: rgb(var(--brand-link-rgb));
    }
    a.toc-link[data-active='true'] {
      background: rgb(var(--brand-primary-rgb) / 0.14);
      color: rgb(var(--brand-link-rgb));
    }
  </style>
</BaseLayout>
