---
import BaseLayout from '../layouts/BaseLayout.astro';
import PromptGenerator from '../components/PromptGenerator.astro';
import MarkdownTool from '../components/MarkdownTool.astro';
import JsonTool from '../components/JsonTool.astro';
import SnakesAndLadders from '../components/SnakesAndLadders.astro';
---

<BaseLayout title="Tools" description="Utilities and small experiments." containerClass="max-w-7xl">
  <div class="space-y-10">
    <div class="space-y-2">
      <h1 class="text-[32px] font-semibold tracking-tight">Tools</h1>
      <p class="text-lg text-zinc-600 dark:text-zinc-400">
        A small collection of utilities I use while building with AI.
      </p>
    </div>

    <div class="flex flex-wrap gap-3">
      <button
        id="open-prompt-generator"
        type="button"
        class="rounded-xl border border-zinc-200 bg-white px-4 py-2 text-sm font-medium text-zinc-800 shadow-sm hover:bg-zinc-50 dark:border-zinc-800 dark:bg-zinc-950 dark:text-zinc-100 dark:hover:bg-zinc-800"
        aria-controls="prompt-generator"
        aria-expanded="false"
      >
        AI prompt generator
      </button>
      <button
        id="open-markdown-tool"
        type="button"
        class="rounded-xl border border-zinc-200 bg-white px-4 py-2 text-sm font-medium text-zinc-800 shadow-sm hover:bg-zinc-50 dark:border-zinc-800 dark:bg-zinc-950 dark:text-zinc-100 dark:hover:bg-zinc-800"
        aria-controls="markdown-tool"
        aria-expanded="false"
      >
        Markdown formatter
      </button>
      <button
        id="open-json-tool"
        type="button"
        class="rounded-xl border border-zinc-200 bg-white px-4 py-2 text-sm font-medium text-zinc-800 shadow-sm hover:bg-zinc-50 dark:border-zinc-800 dark:bg-zinc-950 dark:text-zinc-100 dark:hover:bg-zinc-800"
        aria-controls="json-tool"
        aria-expanded="false"
      >
        JSON toolkit
      </button>
      <button
        id="open-snakes-ladders"
        type="button"
        class="rounded-xl border border-zinc-200 bg-white px-4 py-2 text-sm font-medium text-zinc-800 shadow-sm hover:bg-zinc-50 dark:border-zinc-800 dark:bg-zinc-950 dark:text-zinc-100 dark:hover:bg-zinc-800"
        aria-controls="snakes-ladders"
        aria-expanded="false"
      >
        Snakes &amp; Ladders
      </button>
    </div>

    <div id="prompt-generator" class="hidden pt-4">
      <div class="mb-4">
        <h2 class="text-[24px] font-semibold tracking-tight">AI prompt generator</h2>
        <p class="mt-2 text-sm text-zinc-600 dark:text-zinc-300">
          Fill the fields below. The prompt updates instantly—copy it and iterate.
        </p>
      </div>

      <PromptGenerator />
    </div>

    <div id="markdown-tool" class="hidden pt-4">
      <div class="mb-4">
        <h2 class="text-[24px] font-semibold tracking-tight">Markdown formatter</h2>
        <p class="mt-2 text-sm text-zinc-600 dark:text-zinc-300">
          Format markdown, align tables, and catch common issues.
        </p>
      </div>

      <MarkdownTool />
    </div>

    <div id="json-tool" class="hidden pt-4">
      <div class="mb-4">
        <h2 class="text-[24px] font-semibold tracking-tight">JSON toolkit</h2>
        <p class="mt-2 text-sm text-zinc-600 dark:text-zinc-300">
          Pretty print, minify, validate, and encode/decode.
        </p>
      </div>

      <JsonTool />
    </div>

    <div id="snakes-ladders" class="hidden pt-4">
      <div class="mb-4">
        <h2 class="text-[24px] font-semibold tracking-tight">Snakes &amp; Ladders</h2>
        <p class="mt-2 text-sm text-zinc-600 dark:text-zinc-300">
          Roll the dice and reach 100.
        </p>
      </div>

      <SnakesAndLadders compact />
    </div>
  </div>

  <script is:inline>
    (() => {
      const tools = [
        {
          buttonId: 'open-prompt-generator',
          panelId: 'prompt-generator',
          focusId: 'role',
          hash: '#prompt-generator',
        },
        {
          buttonId: 'open-markdown-tool',
          panelId: 'markdown-tool',
          focusId: 'md-input',
          hash: '#markdown-tool',
        },
        {
          buttonId: 'open-json-tool',
          panelId: 'json-tool',
          focusId: 'json-input',
          hash: '#json-tool',
        },
        {
          buttonId: 'open-snakes-ladders',
          panelId: 'snakes-ladders',
          focusId: '',
          hash: '#snakes-ladders',
        },
      ];

      const entries = tools
        .map((t) => ({
          ...t,
          btn: document.getElementById(t.buttonId),
          panel: document.getElementById(t.panelId),
        }))
        .filter((t) => t.btn && t.panel);

      if (entries.length === 0) return;

      const hideAll = () => {
        for (const t of entries) {
          t.panel.classList.add('hidden');
          t.btn.setAttribute('aria-expanded', 'false');
        }
      };

      const open = (panelId, focusId, btn) => {
        hideAll();
        const panel = document.getElementById(panelId);
        if (!panel) return;
        panel.classList.remove('hidden');
        if (btn) btn.setAttribute('aria-expanded', 'true');
        panel.scrollIntoView({ behavior: 'smooth', block: 'start' });
        const first = focusId ? document.getElementById(focusId) : null;
        if (first && first instanceof HTMLElement) {
          first.focus();
          return;
        }

        const fallback = panel.querySelector('input, textarea, button, a[href], [tabindex]:not([tabindex="-1"])');
        if (fallback && fallback instanceof HTMLElement) fallback.focus();
      };

      for (const t of entries) {
        t.btn.addEventListener('click', (e) => {
          e.preventDefault();
          history.replaceState(null, '', t.hash);
          open(t.panelId, t.focusId, t.btn);
        });
      }

      const fromHash = entries.find((t) => location.hash === t.hash);
      if (fromHash) {
        open(fromHash.panelId, fromHash.focusId, fromHash.btn);
      }
    })();
  </script>
</BaseLayout>
