---
---

<div class="space-y-8">
  <div class="lg:grid lg:grid-cols-[minmax(0,1fr)_minmax(0,1fr)] lg:gap-8 space-y-8 lg:space-y-0">
    <form id="prompt-form" class="space-y-5">
      <div class="space-y-2">
        <label for="role" class="block text-sm font-medium text-zinc-700 dark:text-zinc-200">Role</label>
        <input
          id="role"
          name="role"
          type="text"
          placeholder="e.g., a senior data analyst"
          class="w-full rounded-xl border border-zinc-200 bg-white px-4 py-3 text-sm text-zinc-900 shadow-sm outline-none focus:border-zinc-400 dark:border-zinc-800 dark:bg-zinc-900 dark:text-zinc-50"
        />
      </div>

      <div class="space-y-2">
        <label for="task" class="block text-sm font-medium text-zinc-700 dark:text-zinc-200">Task</label>
        <textarea
          id="task"
          name="task"
          rows={3}
          placeholder="What should the AI do?"
          class="w-full rounded-xl border border-zinc-200 bg-white px-4 py-3 text-sm text-zinc-900 shadow-sm outline-none focus:border-zinc-400 dark:border-zinc-800 dark:bg-zinc-900 dark:text-zinc-50"
        ></textarea>
      </div>

      <div class="space-y-2">
        <label for="context" class="block text-sm font-medium text-zinc-700 dark:text-zinc-200">Context</label>
        <textarea
          id="context"
          name="context"
          rows={3}
          placeholder="Why are we doing this? Who is it for?"
          class="w-full rounded-xl border border-zinc-200 bg-white px-4 py-3 text-sm text-zinc-900 shadow-sm outline-none focus:border-zinc-400 dark:border-zinc-800 dark:bg-zinc-900 dark:text-zinc-50"
        ></textarea>
      </div>

      <div class="space-y-2">
        <label for="constraints" class="block text-sm font-medium text-zinc-700 dark:text-zinc-200">Constraints</label>
        <textarea
          id="constraints"
          name="constraints"
          rows={4}
          placeholder="One per line. e.g., Keep it under 200 words\nDo not use bullet points"
          class="w-full rounded-xl border border-zinc-200 bg-white px-4 py-3 text-sm text-zinc-900 shadow-sm outline-none focus:border-zinc-400 dark:border-zinc-800 dark:bg-zinc-900 dark:text-zinc-50"
        ></textarea>
      </div>

      <div class="space-y-2">
        <label for="format" class="block text-sm font-medium text-zinc-700 dark:text-zinc-200">Output format</label>
        <input
          id="format"
          name="format"
          type="text"
          placeholder="e.g., Output as a markdown table"
          class="w-full rounded-xl border border-zinc-200 bg-white px-4 py-3 text-sm text-zinc-900 shadow-sm outline-none focus:border-zinc-400 dark:border-zinc-800 dark:bg-zinc-900 dark:text-zinc-50"
        />
      </div>

      <div class="flex flex-wrap gap-3">
        <button
          id="copy-btn"
          type="button"
          class="rounded-xl border border-zinc-200 bg-white px-4 py-2 text-sm font-medium text-zinc-800 shadow-sm hover:bg-zinc-50 dark:border-zinc-800 dark:bg-zinc-950 dark:text-zinc-100 dark:hover:bg-zinc-800"
        >
          Copy prompt
        </button>
        <button
          id="example-btn"
          type="button"
          class="rounded-xl border border-zinc-200 bg-white px-4 py-2 text-sm font-medium text-zinc-800 shadow-sm hover:bg-zinc-50 dark:border-zinc-800 dark:bg-zinc-950 dark:text-zinc-100 dark:hover:bg-zinc-800"
        >
          Fill example
        </button>
        <button
          id="reset-btn"
          type="button"
          class="rounded-xl border border-zinc-200 bg-white px-4 py-2 text-sm font-medium text-zinc-800 shadow-sm hover:bg-zinc-50 dark:border-zinc-800 dark:bg-zinc-950 dark:text-zinc-100 dark:hover:bg-zinc-800"
        >
          Reset
        </button>
      </div>
    </form>

    <div class="space-y-3">
      <div class="flex items-center justify-between gap-3">
        <h3 class="text-[20px] font-semibold tracking-tight">Generated prompt</h3>
        <div id="copy-status" class="text-sm text-zinc-500 dark:text-zinc-400"></div>
      </div>

      <pre class="relative overflow-auto rounded-2xl border border-zinc-200 bg-white p-4 text-sm text-zinc-900 shadow-sm dark:border-zinc-800 dark:bg-zinc-950 dark:text-zinc-100"><code id="output"></code></pre>

      <p class="text-sm text-zinc-600 dark:text-zinc-400">
        Tip: if any field is empty, the generator will omit that section.
      </p>
    </div>
  </div>
</div>

<script is:inline>
  (() => {
    const roleEl = document.getElementById('role');
    const taskEl = document.getElementById('task');
    const contextEl = document.getElementById('context');
    const constraintsEl = document.getElementById('constraints');
    const formatEl = document.getElementById('format');
    const outputEl = document.getElementById('output');
    const copyBtn = document.getElementById('copy-btn');
    const resetBtn = document.getElementById('reset-btn');
    const exampleBtn = document.getElementById('example-btn');
    const copyStatus = document.getElementById('copy-status');

    if (!roleEl || !taskEl || !contextEl || !constraintsEl || !formatEl || !outputEl || !copyBtn || !resetBtn || !exampleBtn || !copyStatus) {
      return;
    }

    const getValue = (el) => ('value' in el ? String(el.value).trim() : '');

    const build = () => {
      const role = getValue(roleEl);
      const task = getValue(taskEl);
      const context = getValue(contextEl);
      const constraints = getValue(constraintsEl)
        .split(/\r?\n/)
        .map((l) => l.trim())
        .filter(Boolean);
      const format = getValue(formatEl);

      const parts = [];

      if (role) parts.push(`You are ${role}.`);
      if (task) parts.push(`Task: ${task}`);
      if (context) parts.push(`Context: ${context}`);

      if (constraints.length > 0) {
        parts.push('Constraints:');
        for (const c of constraints) parts.push(`- ${c}`);
      }

      if (format) parts.push(`Output format: ${format}`);

      parts.push('If anything is unclear or missing, ask clarifying questions before answering.');

      outputEl.textContent = parts.join('\n');
    };

    const copyToClipboard = async (text) => {
      try {
        if (navigator.clipboard && navigator.clipboard.writeText) {
          await navigator.clipboard.writeText(text);
          return true;
        }
      } catch {
        return false;
      }

      try {
        const el = document.createElement('textarea');
        el.value = text;
        el.setAttribute('readonly', '');
        el.style.position = 'fixed';
        el.style.left = '-9999px';
        document.body.appendChild(el);
        el.select();
        document.execCommand('copy');
        document.body.removeChild(el);
        return true;
      } catch {
        return false;
      }
    };

    const setStatus = (text) => {
      copyStatus.textContent = text;
      if (text) {
        setTimeout(() => {
          if (copyStatus.textContent === text) copyStatus.textContent = '';
        }, 1200);
      }
    };

    const reset = () => {
      roleEl.value = '';
      taskEl.value = '';
      contextEl.value = '';
      constraintsEl.value = '';
      formatEl.value = '';
      build();
    };

    const fillExample = () => {
      roleEl.value = 'a senior technical writer and product documentation specialist';
      taskEl.value = 'Rewrite the following feature description so it is clear, concise, and user-focused.';
      contextEl.value = 'This will be used as release notes for a developer audience.';
      constraintsEl.value = [
        'Keep it under 180 words',
        'Do not add new features or claims',
        'Use simple language, avoid jargon',
        'Output only the final text (no explanations)',
      ].join('\n');
      formatEl.value = 'A single short paragraph.';
      build();
    };

    const init = () => {
      build();

      const els = [roleEl, taskEl, contextEl, constraintsEl, formatEl];
      for (const el of els) {
        el.addEventListener('input', build);
      }

      copyBtn.addEventListener('click', async () => {
        const text = outputEl.textContent || '';
        const ok = await copyToClipboard(text);
        setStatus(ok ? 'Copied' : 'Copy failed');
      });

      resetBtn.addEventListener('click', reset);
      exampleBtn.addEventListener('click', fillExample);
    };

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
  })();
</script>
