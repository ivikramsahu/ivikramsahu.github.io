---
import '../styles/global.css';

type Props = {
  title?: string;
  description?: string;
  containerClass?: string;
};

const { title, description, containerClass = 'max-w-6xl' } = Astro.props;
const siteName = "Vikram's Focushours";
const metaTitle = title ? `${title} | ${siteName}` : siteName;
const metaDescription = description ?? 'Writing and notes.';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={metaDescription} />

    <script is:inline>
      (() => {
        const storageKey = 'theme';
        const getAutoTheme = () => {
          const hour = new Date().getHours();
          return hour >= 7 && hour < 19 ? 'light' : 'dark';
        };

        const readStored = () => {
          try {
            return localStorage.getItem(storageKey);
          } catch {
            return null;
          }
        };

        const writeStored = (value) => {
          try {
            localStorage.setItem(storageKey, value);
          } catch {
            // ignore
          }
        };

        const applyTheme = (theme) => {
          document.documentElement.classList.toggle('dark', theme === 'dark');
          document.documentElement.dataset.theme = theme;
          window.dispatchEvent(new Event('themechange'));
        };

        const applyStoredOrAuto = () => {
          const stored = readStored();
          if (stored === 'dark' || stored === 'light') {
            applyTheme(stored);
            return;
          }

          applyTheme(getAutoTheme());
        };

        const scheduleAuto = () => {
          const stored = readStored();
          if (stored === 'dark' || stored === 'light') return;

          const now = new Date();
          const hour = now.getHours();
          const next = new Date(now);

          if (hour < 7) {
            next.setHours(7, 0, 0, 0);
          } else if (hour < 19) {
            next.setHours(19, 0, 0, 0);
          } else {
            next.setDate(now.getDate() + 1);
            next.setHours(7, 0, 0, 0);
          }

          const delay = Math.max(1, next.getTime() - now.getTime());
          setTimeout(() => {
            applyStoredOrAuto();
            scheduleAuto();
          }, delay);
        };

        applyStoredOrAuto();
        scheduleAuto();

        window.__setTheme = (nextTheme) => {
          if (nextTheme === 'auto') {
            try {
              localStorage.removeItem(storageKey);
            } catch {
              // ignore
            }
            applyStoredOrAuto();
            scheduleAuto();
            return;
          }

          writeStored(nextTheme);
          applyTheme(nextTheme);
        };

        window.__toggleTheme = () => {
          const current = document.documentElement.classList.contains('dark') ? 'dark' : 'light';
          window.__setTheme(current === 'dark' ? 'light' : 'dark');
        };
      })();
    </script>

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" sizes="any" />
    <link rel="shortcut icon" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Mona+Sans:ital,wght@0,200..900;1,200..900&display=swap"
      rel="stylesheet"
    />

    <title>{metaTitle}</title>
  </head>
  <body class="min-h-screen font-sans flex flex-col bg-zinc-50 text-zinc-900 transition-colors duration-300 dark:bg-zinc-950 dark:text-zinc-50">
    <header class="sticky top-0 z-50 border-b border-zinc-200 bg-white/70 backdrop-blur transition-colors duration-300 dark:border-zinc-800 dark:bg-zinc-950/70">
      <div class={`mx-auto flex ${containerClass} flex-wrap items-center justify-between gap-4 px-4 py-4`}>
        <a href="/" class="flex min-w-0 items-center gap-3 no-underline">
          <picture>
            <source srcset="/mascot.png" type="image/png" />
            <img src="/mascot.svg" alt="Vikram mascot" class="h-[75px] w-[75px]" />
          </picture>
          <span
            id="site-title"
            class="font-hal truncate text-[30px] leading-none font-semibold tracking-tight text-black dark:text-zinc-50"
            data-typing-text={siteName}
          >
            <span id="site-title-prefix"></span><span id="site-title-word"></span><span id="site-title-cursor" aria-hidden="true">_</span>
          </span>
        </a>
        <nav class="flex shrink-0 items-center gap-4 text-[16px]">
          <a
            href="/tools/"
            class="no-underline text-zinc-700 hover:text-[rgb(var(--brand-link-rgb))] dark:text-zinc-300 dark:hover:text-[rgb(var(--brand-link-rgb))]"
          >
            Tools
          </a>
          <a
            href="/"
            class="no-underline text-zinc-700 hover:text-[rgb(var(--brand-link-rgb))] dark:text-zinc-300 dark:hover:text-[rgb(var(--brand-link-rgb))]"
          >
            Blog
          </a>
          <a
            href="/about/"
            class="no-underline text-zinc-700 hover:text-[rgb(var(--brand-link-rgb))] dark:text-zinc-300 dark:hover:text-[rgb(var(--brand-link-rgb))]"
          >
            About
          </a>
          <button
            id="theme-toggle"
            type="button"
            class="relative grid h-9 w-9 place-items-center overflow-hidden rounded-lg border border-zinc-200 bg-white text-zinc-700 hover:bg-zinc-50 hover:text-zinc-900 dark:border-zinc-800 dark:bg-zinc-900 dark:text-zinc-200 dark:hover:bg-zinc-800 dark:hover:text-white"
            aria-label="Toggle theme"
          >
            <span class="sr-only">Toggle theme</span>
            <svg
              class="h-5 w-5 transition-all duration-300 ease-out opacity-100 scale-100 rotate-0 dark:opacity-0 dark:scale-50 dark:-rotate-90"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79Z" />
            </svg>
            <svg
              class="absolute h-5 w-5 transition-all duration-300 ease-out opacity-0 scale-50 rotate-90 dark:opacity-100 dark:scale-100 dark:rotate-0"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <circle cx="12" cy="12" r="4" />
              <path d="M12 2v2" />
              <path d="M12 20v2" />
              <path d="m4.93 4.93 1.41 1.41" />
              <path d="m17.66 17.66 1.41 1.41" />
              <path d="M2 12h2" />
              <path d="M20 12h2" />
              <path d="m6.34 17.66-1.41 1.41" />
              <path d="m19.07 4.93-1.41 1.41" />
            </svg>
          </button>
        </nav>
      </div>
    </header>

    <script is:inline>
      (() => {
        const storageKey = 'theme';

        const readStored = () => {
          try {
            return localStorage.getItem(storageKey);
          } catch {
            return null;
          }
        };

        const writeStored = (value) => {
          try {
            localStorage.setItem(storageKey, value);
          } catch {
            // ignore
          }
        };

        const applyTheme = (theme) => {
          document.documentElement.classList.toggle('dark', theme === 'dark');
          document.documentElement.dataset.theme = theme;
        };

        const getCurrent = () =>
          document.documentElement.classList.contains('dark') ? 'dark' : 'light';

        const getAutoTheme = () => {
          const hour = new Date().getHours();
          return hour >= 7 && hour < 19 ? 'light' : 'dark';
        };

        const applyStoredOrAuto = () => {
          const stored = readStored();
          if (stored === 'dark' || stored === 'light') {
            applyTheme(stored);
            return;
          }
          applyTheme(getAutoTheme());
        };

        const init = () => {
          const btn = document.getElementById('theme-toggle');
          if (!btn) return;

          const sync = () => {
            btn.setAttribute('aria-pressed', String(getCurrent() === 'dark'));
          };

          btn.addEventListener('click', () => {
            window.__toggleTheme();
            sync();
          });

          window.addEventListener('themechange', sync);

          const stored = readStored();
          if (stored === 'dark' || stored === 'light') applyTheme(stored);
          else applyStoredOrAuto();
          sync();
        };

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', init);
        } else {
          init();
        }
      })();
    </script>

    <script is:inline>
      (() => {
        const copyText = async (text) => {
          try {
            if (navigator.clipboard && navigator.clipboard.writeText) {
              await navigator.clipboard.writeText(text);
              return true;
            }
          } catch {
            // ignore
          }

          try {
            const el = document.createElement('textarea');
            el.value = text;
            el.setAttribute('readonly', '');
            el.style.position = 'fixed';
            el.style.left = '-9999px';
            document.body.appendChild(el);
            el.select();
            document.execCommand('copy');
            document.body.removeChild(el);
            return true;
          } catch {
            return false;
          }
        };

        const init = () => {
          const pres = Array.from(document.querySelectorAll('pre'));
          for (const pre of pres) {
            if (!(pre instanceof HTMLElement)) continue;
            if (pre.querySelector('.code-copy-btn')) continue;

            const code = pre.querySelector('code');
            if (!code) continue;

            const btn = document.createElement('button');
            btn.type = 'button';
            btn.className = 'code-copy-btn';
            btn.textContent = 'Copy';
            btn.setAttribute('aria-label', 'Copy code');

            btn.addEventListener('click', async (e) => {
              e.preventDefault();
              e.stopPropagation();

              const text = code.textContent ?? '';
              const ok = await copyText(text);
              const prev = btn.textContent;
              btn.textContent = ok ? 'Copied' : 'Failed';
              btn.disabled = true;
              setTimeout(() => {
                btn.textContent = prev;
                btn.disabled = false;
              }, 1200);
            });

            pre.appendChild(btn);
          }
        };

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', init);
        } else {
          init();
        }
      })();
    </script>

    <style is:inline>
      #site-title {
        white-space: nowrap;
      }

      #site-title-cursor {
        display: inline-block;
        margin-left: 1px;
        opacity: 1;
      }

      @media (prefers-reduced-motion: reduce) {
        #site-title-cursor {
          display: none;
        }
      }
    </style>

    <script is:inline>
      (() => {
        const run = () => {
          if (window.__siteTitleLoopRunning) return;
          window.__siteTitleLoopRunning = true;

          const host = document.getElementById('site-title');
          const prefixEl = document.getElementById('site-title-prefix');
          const wordEl = document.getElementById('site-title-word');
          const cursorEl = document.getElementById('site-title-cursor');

          if (!host || !prefixEl || !wordEl || !cursorEl) return;

          const prefersReduced =
            typeof window !== 'undefined' &&
            window.matchMedia &&
            window.matchMedia('(prefers-reduced-motion: reduce)').matches;

          const prefix = "Vikram's ";
          const words = ['Focushours', 'Blog', 'Tools', 'Experiments'];

          if (prefersReduced) {
            prefixEl.textContent = prefix;
            wordEl.textContent = words[0];
            cursorEl.style.display = 'none';
            return;
          }

          const sleep = (ms) => new Promise((r) => window.setTimeout(r, ms));

          const typeInto = async (el, text, delay) => {
            el.textContent = '';
            for (let i = 0; i < text.length; i += 1) {
              el.textContent += text[i];
              await sleep(delay);
            }
          };

          const backspace = async (el, delay) => {
            while (el.textContent && el.textContent.length > 0) {
              el.textContent = el.textContent.slice(0, -1);
              await sleep(delay);
            }
          };

          const blinkCursor = async (times) => {
            for (let i = 0; i < times; i += 1) {
              cursorEl.style.opacity = '0';
              await sleep(500);
              cursorEl.style.opacity = '1';
              await sleep(500);
            }
          };

          (async () => {
            prefixEl.textContent = '';
            wordEl.textContent = '';
            cursorEl.style.opacity = '1';

            await typeInto(prefixEl, prefix, 55);
            await typeInto(wordEl, words[0], 70);

            let idx = 0;
            while (true) {
              await blinkCursor(3);
              await backspace(wordEl, 35);
              idx = (idx + 1) % words.length;
              await typeInto(wordEl, words[idx], 70);
            }
          })();
        };

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', run);
        } else {
          run();
        }
      })();
    </script>

    <div
      id="toast"
      class="pointer-events-none fixed bottom-5 left-1/2 z-[60] transition-all duration-200"
      aria-live="polite"
      aria-atomic="true"
    >
      <div
        id="toast-inner"
        class="rounded-xl border border-zinc-200 bg-white/90 px-4 py-2 text-sm font-medium text-zinc-900 shadow-lg backdrop-blur dark:border-zinc-800 dark:bg-zinc-950/90 dark:text-zinc-50"
      ></div>
    </div>

    <style is:inline>
      #toast {
        opacity: 0;
        transform: translate(-50%, 12px);
      }
      #toast[data-open='true'] {
        opacity: 1;
        transform: translate(-50%, 0);
      }
    </style>

    <script is:inline>
      (() => {
        let hideTimer;

        window.__toast = (message) => {
          const host = document.getElementById('toast');
          const inner = document.getElementById('toast-inner');
          if (!host || !inner) return;

          inner.textContent = String(message || 'Copied');

          host.dataset.open = 'true';

          if (hideTimer) window.clearTimeout(hideTimer);
          hideTimer = window.setTimeout(() => {
            delete host.dataset.open;
          }, 1200);
        };
      })();
    </script>

    <main class={`mx-auto w-full ${containerClass} flex-1 px-4 py-10`}>
      <slot />
    </main>

    <footer class="border-t border-zinc-200 dark:border-zinc-800">
      <div class={`mx-auto ${containerClass} px-4 py-8 text-center text-sm text-zinc-600 dark:text-zinc-400`}>
        <div>
          Made with ❤ by
          <a
            href="https://www.linkedin.com/in/ivikramsahu/"
            class="no-underline font-medium text-zinc-700 hover:text-[rgb(var(--brand-link-rgb))] dark:text-zinc-200 dark:hover:text-[rgb(var(--brand-link-rgb))]"
            target="_blank"
            rel="noopener noreferrer"
          >
          vikramsahu
          </a>
        </div>
        <div class="mt-2">© 2026</div>
      </div>
    </footer>
  </body>
</html>
